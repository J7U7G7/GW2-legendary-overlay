{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GW2 Overlay",
  "version": "0.1.0",
  "identifier": "com.tripleseptconsulting.gw2overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GW2 Configure",
        "width": 380,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "url": "index.html#main"
      },
      {
        "label": "bosses",
        "title": "GW2 Bosses",
        "width": 380,
        "height": 500,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "url": "index.html#bosses"
      },
      {
        "label": "achievements",
        "title": "GW2 Achievements",
        "width": 380,
        "height": 500,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "url": "index.html#achievements"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
