{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GW2 Overlay",
  "version": "0.1.0",
  "identifier": "com.tripleseptconsulting.gw2overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GW2 Configure",
        "width": 380,
        "height": 600,
        "minWidth": 320,
        "minHeight": 220,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "url": "index.html#main"
      },
      {
        "label": "bosses",
        "title": "GW2 Bosses",
        "width": 380,
        "height": 500,
        "minWidth": 240,
        "minHeight": 160,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "url": "index.html#bosses"
      },
      {
        "label": "achievements",
        "title": "GW2 Achievements",
        "width": 380,
        "height": 500,
        "minWidth": 240,
        "minHeight": 160,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "url": "index.html#achievements"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/J7U7G7/GW2-legendary-overlay/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFQUIzNUYxOEU4RkI3NzcKUldSM3Q0K084VFdyN2xqdXhZTGpSMkpRUyt1WjBkTkNkejk5VjhFSElTNk1TbWRxd0RDNkhneXkK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
